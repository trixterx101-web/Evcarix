GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_gemini_api_key_2_here
GEMINI_API_KEY_3=your_gemini_api_key_3_here

PEXELS_API_KEY=your_pexels_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=your_groq_api_key_2_here
GROQ_API_KEY_3=your_groq_api_key_3_here

PIXABAY_API_KEY=your_pixabay_api_key_here

STABILITY_API_KEY=your_stability_api_key_here
REPLICATE_API_KEY=your_replicate_api_key_here
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here

# ── Lip-Sync Video Generation (Wav2Lip) ────────────────────────────────────────
# Set to "true" to enable lip-sync mode (character speaking video)
USE_LIP_SYNC=false

# Path to character portrait image for lip-sync
CHARACTER_IMAGE=assets/character.jpg

# Note: Uses existing GROQ_API_KEY and voice engine - no additional keys needed

YOUTUBE_CLIENT_SECRET_FILE=client_secret.json

# Diğer ayarlar
LOG_LEVEL=INFO
UPLOAD_SLOT=evening  # evening | night
