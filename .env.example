# ═══════════════════════════════════════════════════════════════
# Evcarix Auto-Studio — Ortam Değişkenleri
# ═══════════════════════════════════════════════════════════════

# ── LLM API Key'leri (öncelik sırası) ───────────────────────────

# 1. Gemini — https://aistudio.google.com (ücretsiz, önerilir)
GEMINI_API_KEY=                    # LLM — ücretsiz
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# 2. Groq — https://console.groq.com (ücretsiz, hızlı)
GROQ_API_KEY=                      # LLM fallback — ücretsiz
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# 3. OpenRouter — https://openrouter.ai/keys (200+ model, ücretsiz tier)
OPENROUTER_API_KEY=

# 4. Mistral — https://console.mistral.ai (ücretsiz tier)
MISTRAL_API_KEY=

# 5. Cohere — https://dashboard.cohere.com/api-keys (günde 20 ücretsiz)
COHERE_API_KEY=

# 6. Together AI — https://api.together.xyz (ilk $5 ücretsiz)
TOGETHER_API_KEY=

# 7. Perplexity — https://www.perplexity.ai/settings/api (ilk $5 ücretsiz)
PERPLEXITY_API_KEY=

# 8. DeepSeek — https://platform.deepseek.com/api_keys ($0.14/1M token)
DEEPSEEK_API_KEY=

# 9. HuggingFace — https://huggingface.co/settings/tokens (ücretsiz)
HUGGINGFACE_API_KEY=

# ── YouTube ─────────────────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_PATH=token.json
CHANNEL_ID=
YOUTUBE_REGION=US
UPLOAD_SLOT=evening

# ── Video Kaynakları ────────────────────────────────────────────
PEXELS_API_KEY=                   # Stok video — ücretsiz
PIXABAY_API_KEY=                  # Stok video — ücretsiz
COVERR_API_KEY=
COVERR_APP_ID=

# ── AI Video (opsiyonel) ─────────────────────────────────────────
STABILITY_API_KEY=
REPLICATE_API_KEY=
REPLICATE_API_TOKEN=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
FAL_KEY=                          # AI video — ücretsiz kredi
HF_TOKEN=                         # HuggingFace — ücretsiz

# ── HuggingFace ─────────────────────────────────────────────────
HUGGINGFACE_API_KEY=

# ── GitHub ───────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── Diğer API Key'ler ───────────────────────────────────────────
DASHSCOPE_API_KEY=

# ── Diğer ────────────────────────────────────────────────────────
USE_LIP_SYNC=false
CHARACTER_IMAGE=assets/character.jpg
