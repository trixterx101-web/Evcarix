# ─── LLM API Key'leri — Öncelik sırasıyla ────────────────────────────────────
# 1. Gemini (zaten var)
GEMINI_API_KEY=

# 2. Groq — https://console.groq.com (ücretsiz, hızlı)
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# 3. OpenRouter — https://openrouter.ai/keys (200+ model, ücretsiz tier)
OPENROUTER_API_KEY=

# 4. Mistral — https://console.mistral.ai (ücretsiz tier)
MISTRAL_API_KEY=

# 5. Cohere — https://dashboard.cohere.com/api-keys (günde 20 ücretsiz istek)
COHERE_API_KEY=

# 6. Together AI — https://api.together.xyz (ilk $5 ücretsiz)
TOGETHER_API_KEY=

# 7. Perplexity — https://www.perplexity.ai/settings/api (ilk $5 ücretsiz)
PERPLEXITY_API_KEY=

# 8. DeepSeek — https://platform.deepseek.com/api_keys (çok ucuz)
DEEPSEEK_API_KEY=

# 9. HuggingFace — https://huggingface.co/settings/tokens (ücretsiz)
HUGGINGFACE_API_KEY=

# 10. Ollama — yerel LLM, internet gerekmez (GitHub Actions'da çalışmaz)
OLLAMA_URL=http://localhost:11434

# ─── YouTube ──────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_PATH=token.json
CHANNEL_ID=
YOUTUBE_REGION=US
UPLOAD_SLOT=evening

# ─── Video Kaynakları ─────────────────────────────────────────────────────────
PEXELS_API_KEY=
PIXABAY_API_KEY=
COVERR_API_KEY=

# ─── AI Video (opsiyonel) ─────────────────────────────────────────────────────
STABILITY_API_KEY=
REPLICATE_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# ─── Other Settings ───────────────────────────────────────────────────
LOG_LEVEL=INFO
CONTENT_MODE=auto
