GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_gemini_api_key_2_here
GEMINI_API_KEY_3=your_gemini_api_key_3_here

PEXELS_API_KEY=your_pexels_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=your_groq_api_key_2_here
GROQ_API_KEY_3=your_groq_api_key_3_here

PIXABAY_API_KEY=your_pixabay_api_key_here
COVERR_API_KEY=your_coverr_api_key_here

STABILITY_API_KEY=your_stability_api_key_here
REPLICATE_API_TOKEN=your_replicate_api_token_here
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here
DASHSCOPE_API_KEY=your_qwen_dashscope_api_key_here
HF_TOKEN=your_huggingface_token_here

# ── YouTube OAuth ────────────────────────────────────────────────────
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_PATH=token.json
CHANNEL_ID=UC_YOUR_CHANNEL_ID

# ── Lip-Sync Video Generation (Wav2Lip) ────────────────────────────────────────
# Set to "true" to enable lip-sync mode (character speaking video)
USE_LIP_SYNC=false

# Path to character portrait image for lip-sync
CHARACTER_IMAGE=assets/character.jpg

# ── Other Settings ───────────────────────────────────────────────────
LOG_LEVEL=INFO
UPLOAD_SLOT=evening
YOUTUBE_REGION=US

# ── Content Mode (GitHub Actions tarafından otomatik ayarlanır) ─────
# trend: YouTube trend'ten ilham al (TR 10:00 / UTC 07:00)
# auto:  Sistem otomatik konu seçer (TR 16:00 / UTC 13:00)
CONTENT_MODE=auto

# ── Multi-LLM Backup APIs for Trend Engine ───────────────────────────
# Yeni trend motoru için ek LLM API key'leri (tümü opsiyonel)
OPENROUTER_API_KEY=your_openrouter_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
COHERE_API_KEY=your_cohere_api_key_here
TOGETHER_API_KEY=your_together_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
OLLAMA_URL=http://localhost:11434
